{
    "source": "src",
    "destination": "ernyoke.github.io",
    "hostname": "ervinszilagyi.dev",
    "baseHref": "http://127.0.0.1:8080",
    "meta": {
        "default": {
            "og:title": "Ervin Szilágyi - Personal site",
            "og:image": "images/cover.png",
            "og:description": "Personal web page and blog.",
            "og:url": "https://ervinszilagyi.dev",
            "twitter_handle": "@ervin_szilagyi",
            "og:author": "Ervin Szilagyi",
            "author_email": "ervin_szilagyi[at]outlook.com"
        },
        "matchers": [
            {
                "file": "resume.md",
                "action": "STATIC",
                "meta": {
                    "og:title": "Resume",
                    "og:description": "Ervin's résumé",
                    "og:url": "https://ervinszilagyi.dev/resume.html"
                }
            },
            {
                "file": "index.md",
                "action": "USE_DEFAULT"
            },
            {
                "file": "*.md",
                "action": "TAKE_FROM_CONTENT"
            },
            {
                "file": "articles/*",
                "action": "TAKE_FROM_CONTENT"
            }
        ]
    },
    "frames": [
        {
            "file": "index.md",
            "frame": "index_frame.html"
        },
        {
            "file": "resume.md",
            "frame": "src/resume_frame.html"
        },
        {
            "file": "articles/*.md",
            "frame": "articles/article_frame.html"
        },
        {
            "file": "*.md",
            "frame": "frame.html"
        }
    ],
    "rssFeeds": [
        {
            "title": "Blog posts and articles - ervinszilagyi.dev",
            "description": "Latest blog posts from ervinszilagyi.dev",
            "link": "https://ervinszilagyi.dev/blog",
            "feed_url": "https://ervinszilagyi.dev/articles/atom.xml",
            "language": "en",
            "matcher": "articles/*.md",
            "limit": 20,
            "outputLocation": "articles/atom.xml"
        }
    ]
}